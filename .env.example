# ============================================================
#  ContentFlow – Environment Variables
#  Copy to .env and fill in real values.
#  NEVER commit .env to source control.
#
#  Infrastructure (all free tiers):
#    MongoDB  → MongoDB Atlas   https://cloud.mongodb.com
#    Redis    → Upstash         https://upstash.com
#    Storage  → Cloudflare R2   https://dash.cloudflare.com/r2
# ============================================================

# ---- Shared ------------------------------------------------
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# ---- MongoDB Atlas -----------------------------------------
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# One connection string per service db (Atlas M0 allows 500 connections)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/contentflow?retryWrites=true&w=majority

# ---- Upstash Redis -----------------------------------------
# Get from: https://console.upstash.com → Create Database → REST URL
# Use the rediss:// (TLS) URL for production
REDIS_URL=rediss://default:xxxxxxxx@global-xxxxxxxx.upstash.io:6379

# ---- Cloudflare R2 (MinIO replacement, S3-compatible) ------
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
AWS_S3_BUCKET=contentflow-media

# ---- CORS --------------------------------------------------
# Render static site URL (set after first deploy)
ALLOWED_ORIGINS=https://contentflow-webapp.onrender.com

# ---- Analytics extras --------------------------------------
API_KEY_SECRET=replace-with-strong-random-secret
SERVICE_TOKEN=replace-with-shared-service-token

# ---- Notification: Twilio (SMS) ----------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ---- Notification: Firebase (Push notifications) -----------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ---- Notification: SMTP (Email) ----------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
